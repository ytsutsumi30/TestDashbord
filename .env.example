# ============================================================
# TestDashboard 環境変数 (.env)
# ============================================================
# 使い方:
#   1. このファイルを .env にコピー
#   2. 値を埋める
#   3. PowerShell で:
#        Get-Content .env | ForEach-Object {
#          if ($_ -match '^([^=]+)=(.+)$') {
#            [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#          }
#        }
#      または dotenv パッケージで読込
# ============================================================

# サーバー設定
PORT=3000
CORS_ORIGIN=*

# Azure Speech 連携
# Mock=true なら実APIを叩かずに固定 transcript を返す (開発初期推奨)
AZURE_SPEECH_MOCK=true
AZURE_SPEECH_REGION=japaneast
AZURE_SPEECH_KEY=

# 音声ファイル公開モード
#   local : Express から /public-audio/<token>/<filename> で発行 (デフォルト)
#   blob  : Azure Blob Storage に upload して SAS URL を発行
PUBLISH_MODE=local

# 公開時のベースURL (cloudflared 起動時のトンネル URL に書き換える)
#   - Azure Speech が直接取得できる必要があるため、外部到達URLが必須
#   - Mock モード時は無視される
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# blob モード時のみ必要
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=transcripts
