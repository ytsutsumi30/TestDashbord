# ============================================================
# TestDashboard 環境変数 (.env)
# ============================================================
# 使い方:
#   1. このファイルを .env にコピー
#   2. 値を埋める
#   3. PowerShell で:
#        Get-Content .env | ForEach-Object {
#          if ($_ -match '^([^=]+)=(.+)$') {
#            [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#          }
#        }
#      または dotenv パッケージで読込
# ============================================================

# サーバー設定
PORT=3000
CORS_ORIGIN=*

# Azure Speech 連携
# Mock=true なら実APIを叩かずに固定 transcript を返す (開発初期推奨)
AZURE_SPEECH_MOCK=true
AZURE_SPEECH_REGION=japaneast
AZURE_SPEECH_KEY=

# 音声ファイル公開モード
#   local : Express から /public-audio/<token>/<filename> で発行 (デフォルト)
#   blob  : Azure Blob Storage に upload して SAS URL を発行
PUBLISH_MODE=local

# 公開時のベースURL (cloudflared 起動時のトンネル URL に書き換える)
#   - Azure Speech が直接取得できる必要があるため、外部到達URLが必須
#   - Mock モード時は無視される
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# blob モード時のみ必要
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=transcripts

# ============================================================
# 優先度4: functions/ 統合 - Azure Storage Queue コンシューマー
# ============================================================
# functions/notifications (Azure Functions) が Teams webhook を受信し
# Storage Queue "minutes-jobs" にメッセージを積む。
# TestDashboard はここで定義したキューを定期ポーリングして処理する。
#
# ローカル開発 (Azurite) での接続文字列:
#   UseDevelopmentStorage=true
#   または
#   DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;
#
# QUEUE_CONSUMER_MOCK=true の場合はキューポーリングを無効化。
# AZURE_STORAGE_CONNECTION_STRING 未設定時も自動 Mock になる。

QUEUE_NAME=minutes-jobs
QUEUE_POLL_INTERVAL_MS=10000
QUEUE_CONSUMER_MOCK=true

# Microsoft Graph API (Teams transcript 取得 + OneDrive アップロード)
# Application permission 必須: OnlineMeetingTranscript.Read.All, Files.ReadWrite.All
# GRAPH_MOCK=true の場合はモック動作
GRAPH_MOCK=true
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_UPN=
MS_DRIVE_PATH=/Apps/MeetingMinutes

# Claude AI (議事録生成)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MOCK=true

